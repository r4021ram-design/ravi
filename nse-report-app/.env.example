# NSE Daily Report App - Environment Variables
# Copy this to .env and fill in your values

# App
DEBUG=true

# API Keys (optional - enhances data quality)
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=

# Database
DATABASE_URL=postgresql://localhost:5432/nse_report

# Redis
REDIS_URL=redis://localhost:6379/0

# Notifications (optional)
SENDGRID_API_KEY=
TWILIO_SID=
TWILIO_TOKEN=
